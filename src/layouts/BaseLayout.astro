---
import Header from "../components/header.astro";
import Navbar from "../components/navbar_daisy.astro";
import Footer from "../components/footer.astro";
import { ViewTransitions } from "astro:transitions";
const base_url = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="de" data-theme="mtv">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={base_url + "wappen.png"} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>MTV Barfelde</title>
  </head>
  <body class="flex flex-col min-h-screen bg-base-100">
    <Header />
    <Navbar />
    <div class="flex-grow py-2">
      <slot />
    </div>
    <Footer />
  </body>
</html>
