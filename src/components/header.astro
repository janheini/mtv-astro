---
const base_url = import.meta.env.BASE_URL;
---

<div class="flex flex-nowrap items-center bg-background w-full">
  <a href={base_url} class="sm:order-2">
    <div class="m-2">
      <h1 class="text-primary text-5xl font-black">
        MTV Barfelde
      </h1>
      <p class="text-primary">MännerTurnVerein von 1911 e.V.</p>
    </div>
  </a>
  <a href={base_url} class="sm:shrink-0 sm:order-1 mr-1 self-start">
    <img src={base_url + "wappen.png"} class="aspect-square w-24 my-2" />
  </a>
</div>
