---
const base_url = import.meta.env.BASE_URL;
---

<div class="flex items-center bg-background w-full">
  <a href={base_url} class="mr-1 min-w-fit">
    <img src={base_url + "wappen.png"} class="aspect-square w-24 my-2" />
  </a>
  <a href={base_url}>
    <div class="m-2">
      <h1 class="text-primary text-4xl sm:text-5xl font-black">
        MTV Barfelde
      </h1>
      <p class="text-primary">MännerTurnVerein von 1911 e.V.</p>
    </div>
  </a>
</div>
