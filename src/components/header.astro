---
const base_url = import.meta.env.BASE_URL
---
<style>
#header {
    display: flex; 
    color: #6c8644;
    background: #f9fcf7;
    align-items: center;
    padding-top: 1rem;
    padding-bottom: 1rem;
}

#header > * {
    margin-left: 1rem;
}

#title h1 { 
    font-size: 2.5rem;
    font-weight: 900;
    margin-top: 0em;
    margin-bottom: 0em;
}

#title p { 
    margin: 0px;
    padding: 0px;
}


nav {
    padding: 1rem;
    margin-bottom: 2rem;
}

nav a {
    margin: 0rem;
    padding: 1rem;
    color: black;
    font-weight: bold;
    text-decoration: none;
}

nav a:hover {
    margin: 0rem;
    padding: 1rem;
    color: green;
}
</style>

<div id="header">
    <img src={base_url + "wappen.png"} width="80" height="80">
    <div id="title">
        <h1>MTV Barfelde</h1>
        <p>MännerTurnVerein von 1911 e.V.<p>
    </div>
</div>
<nav>
    <a href={base_url}>Aktuelles</a>
    <a href={base_url + "ueber-uns"}>über uns ...</a>
    <a href={base_url + "hsg"}>HSG 09</a>
    <a href={base_url + "unser-sporthaus"}>Sporthaus</a>
    <a href={base_url + "sportarten"}>Sportarten</a>
    <a href={base_url + "dokumente"}>Dokumente</a>
    <a href={base_url + "berichte"}>Berichte</a>
    <a href={base_url + "sportversicherung"}>Sportversicherung</a>
</nav>
