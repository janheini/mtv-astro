      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"></path></svg
  ></button>
  {menu.map((item) => <button class="hover:text-primary w-max hidden mr-8 lg:mr-0 lg:block">{item.text}</button>)}

