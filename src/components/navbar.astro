---
const base_url = import.meta.env.BASE_URL;
const menu = [
  {
    text: "Aktuelles",
    link: base_url,
  },
  {
    text: "über uns ...",
    link: base_url + "ueber-uns",
    submenu: [
      { text: "über uns ...", link: base_url + "ueber-uns" },
      {
        text: "Alles auf einen Blick",
        link: base_url + "alles-auf-einen-blick",
      },
    ],
  },
  {
    text: "HSG 09",
    link: base_url + "hsg",
    submenu: [
      { text: "HSG 09 Gronau/Barfelde", link: base_url + "hsg" },
      { text: "Vorstand", link: base_url + "vorstand" },
      { text: "Trainingszeiten", link: base_url + "trainingszeiten" },
      { text: "Newsletter", link: base_url + "newsletter" },
      { text: "Spielplan", link: base_url + "spielplan" },
    ],
  },
  {
    text: "Sporthaus",
    link: base_url + "unser-sporthaus",
    submenu: [
      { text: "Unser Sporthaus", link: base_url + "unser-sporthaus" },
      { text: "Miete / Preise", link: base_url + "preise" },
      { text: "Belegungsplan", link: base_url + "belegungsplan" },
    ],
  },
  {
    text: "Sportarten",
    link: base_url + "sportarten",
    submenu: [
      { text: "Überblick Sportarten", link: base_url + "sportarten" },
      {
        text: "Gymnastikdamen",
        link: base_url + "sportarten" + "gymnastikdamen",
      },
    ],
  },
  {
    text: "Berichte",
    link: base_url + "berichte",
  },
];
---

<nav
  class="grid grid-flow-row justify-end lg:hidden lg:grid-flow-col lg:justify-start auto-cols-max gap-x-8 gap-y-8 bg-white p-3 mb-8 font-bold"
>
  <button id="menu" value="hide" class="lg:hidden justify-self-end"><svg width="24" height="24"
    ><path
      d="M5 6h14M5 12h14M5 18h14"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"></path></svg
  ></button>
  {menu.map((item) => <button class="hover:text-primary w-max hidden mr-8 lg:mr-0 lg:block"><a href={item.link}>{item.text}</a></button>)}
</nav>

<script defer>
const button = document.getElementById("menu");
button.addEventListener("click", () => {
    const navbar = button.parentElement.children;
    if (button.value === "hide") {
        button.value = "show";
        for (i = 1; i < navbar.length; i++) {
            navbar.item(i).style.display = "block";
        }
    } else {
        button.value = "hide";
        for (i = 1; i < navbar.length; i++) {
            navbar.item(i).style.display = "none";
        }
    }
});
</script>

<nav
  class="hidden lg:flex flex-none flex-wrap items-center gap-x-8 gap-y-8 bg-white p-3 mb-8 font-bold"
>
  {
    menu.map((item) => (
      <button class="group relative">
        <a class="hover:text-primary" href={item.link}>
          {item.text}
        </a>
        {item.submenu && (
          <div class="bg-white absolute w-full px-4 hidden group-hover:block group-focus-within:block">
            {item.submenu.map((item) => (
              <a href={item.link} class="block py-2 hover:text-primary">
                {item.text}
              </a>
            ))}
          </div>
        )}
      </button>
    ))
  }
</nav>
