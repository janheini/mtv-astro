---
import Submenu from "./submenu.astro";

const base_url = import.meta.env.BASE_URL;
const menu = [
  {
    text: "Aktuelles",
    link: base_url,
  },
  {
    text: "über uns ...",
    link: base_url + "ueber-uns",
    submenu: [
      { text: "über uns ...", link: base_url + "ueber-uns" },
      {
        text: "Alles auf einen Blick",
        link: base_url + "alles-auf-einen-blick",
      },
    ],
  },
  {
    text: "HSG 09",
    link: base_url + "hsg",
    submenu: [
      { text: "HSG 09 Gronau/Barfelde", link: base_url + "hsg" },
      { text: "Vorstand", link: base_url + "vorstand" },
      { text: "Trainingszeiten", link: base_url + "trainingszeiten" },
      { text: "Newsletter", link: base_url + "newsletter" },
      { text: "Spielplan", link: base_url + "spielplan" },
    ],
  },
  {
    text: "Sporthaus",
    link: base_url + "unser-sporthaus",
    submenu: [
      { text: "Unser Sporthaus", link: base_url + "unser-sporthaus" },
      { text: "Miete / Preise", link: base_url + "preise" },
      { text: "Belegungsplan", link: base_url + "belegungsplan" },
    ],
  },
  {
    text: "Sportarten",
    link: base_url + "sportarten",
    submenu: [
      { text: "Überblick Sportarten", link: base_url + "sportarten" },
      {
        text: "Gymnastikdamen",
        link: base_url + "sportarten" + "gymnastikdamen",
      },
    ],
  },
  {
    text: "Berichte",
    link: base_url + "berichte",
  },
];
---

<input
  id="toggleMenu"
  class="group peer/toggleMenu appearance-none"
  type="checkbox"
/>
<label for="toggleMenu" class="cursor-pointer lg:hidden">
  <div class="flex justify-center w-screen py-1 border">
    <svg
      class="inline"
      width="40"
      height="40"
      viewBox="0 0 15 15"
      xmlns="http://www.w3.org/2000/svg"
      ><path
        d="M1.5 3C1.22386 3 1 3.22386 1 3.5C1 3.77614 1.22386 4 1.5 4H13.5C13.7761 4 14 3.77614 14 3.5C14 3.22386 13.7761 3 13.5 3H1.5ZM1 7.5C1 7.22386 1.22386 7 1.5 7H13.5C13.7761 7 14 7.22386 14 7.5C14 7.77614 13.7761 8 13.5 8H1.5C1.22386 8 1 7.77614 1 7.5ZM1 11.5C1 11.2239 1.22386 11 1.5 11H13.5C13.7761 11 14 11.2239 14 11.5C14 11.7761 13.7761 12 13.5 12H1.5C1.22386 12 1 11.7761 1 11.5Z"
        fill-rule="evenodd"
        clip-rule="evenodd"></path></svg
    >
  </div>
</label>

<nav
  class="hidden peer-checked/toggleMenu:grid lg:grid grid-flow-row lg:grid-flow-col justify-center lg:justify-start justify-items-center lg:justify-items-start px-6 lg:border gap-x-10 bg-white font-bold"
>
  {
    menu.map((item) => (
      <div class="w-screen lg:w-max border lg:border-0 py-3">
        <button
          class="justify-center lg:px-0 w-full group relative"
          submenu-button
        >
          <a class="topmenu-link hover:text-primary" href={item.link}>
            {item.text}
          </a>
          {item.submenu && <Submenu item={item} />}
        </button>
      </div>
    ))
  }
</nav>
<div class="block w-screen h-6"></div>
